{
    "name": "mahbubur508/api-auth",
    "description": "A robust and fast REST API Authentication package for Laravel using Sanctum.",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../mahbubur508/api-auth",
            "options": {
                "symlink": true
            }
        }
    ],
    "authors": [
        {
            "name": "Md. Mahbubur Rahman",
            "email": "your-email@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
        "laravel/sanctum": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mahbubur508\\ApiAuth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mahbubur508\\ApiAuth\\Providers\\ApiAuthServiceProvider"
            ]
        }
    }
}
